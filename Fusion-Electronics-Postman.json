{
  "info": {
    "name": "Fusion Electronics E-commerce API",
    "description": "Complete Postman collection for the Fusion Electronics backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            }
          }
        },
        {
          "name": "Get Product Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/607d1f77bcf86cd799439011",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "607d1f77bcf86cd799439011"
              ]
            },
            "description": "Replace the ID at the end of the URL with a valid product ID from the 'Get All Products' response."
          }
        },
        {
          "name": "Get Similar Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/607d1f77bcf86cd799439011/similar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "607d1f77bcf86cd799439011",
                "similar"
              ]
            }
          }
        },
        {
          "name": "Get Group Recommendations",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"ids\": [\n        \"607d1f77bcf86cd799439011\",\n        \"607d1f77bcf86cd799439022\"\n    ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/recommendations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "recommendations"
              ]
            }
          }
        },
        {
          "name": "Get Products By Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/category/Electronics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "category",
                "Electronics"
              ]
            }
          }
        },
        {
          "name": "Update Product Rating",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"rating\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/607d1f77bcf86cd799439011/rating",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "607d1f77bcf86cd799439011",
                "rating"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"items\": [\n        {\n            \"productId\": \"607d1f77bcf86cd799439011\",\n            \"quantity\": 2\n        }\n    ],\n    \"name\": \"John Doe\",\n    \"email\": \"johndoe@example.com\",\n    \"shippingAddress\": \"123 Main Street, New York, NY 10001\",\n    \"cardNumber\": \"4242424242424242\",\n    \"cardName\": \"John Doe\",\n    \"expiry\": \"12/28\",\n    \"cvc\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout/create-order",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "checkout",
                "create-order"
              ]
            },
            "description": "Please ensure the productId exists in your database before testing."
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Track Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"orderNumber\": \"FE-123456\",\n    \"email\": \"johndoe@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/track",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "track"
              ]
            },
            "description": "Replace orderNumber and email with details returned from the 'Create Order' API."
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search?q=laptop",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "laptop"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"testuser1@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"testuser1@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Verify Email (Forgot Pwd)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"testuser1@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-email"
              ]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"testuser1@example.com\",\n    \"password\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "reset-password"
              ]
            }
          }
        }
      ]
    }
  ]
}
