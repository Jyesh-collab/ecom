{
  "info": {
    "name": "Fusion Electronics API",
    "description": "Complete API collection for Fusion Electronics ecommerce application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "product_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_number",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.test('Token received', () => pm.expect(res.token).to.exist);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.test('Token received', () => pm.expect(res.token).to.exist);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🛍️ Products",
      "item": [
        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  if (res.length > 0) {",
                  "    pm.collectionVariables.set('product_id', res[0]._id);",
                  "  }",
                  "  pm.test('Products returned', () => pm.expect(res).to.be.an('array'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/{{product_id}}"
          }
        },
        {
          "name": "Get Similar Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/{{product_id}}/similar"
          }
        },
        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/category/Electronics",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "category", "Electronics"]
            }
          }
        },
        {
          "name": "Get AI Recommendations",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/products/recommendations",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_id}}\"\n}"
            }
          }
        },
        {
          "name": "Rate a Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/products/{{product_id}}/rating",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🔍 Search",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/search?q=laptop",
              "host": ["{{base_url}}"],
              "path": ["api", "search"],
              "query": [{ "key": "q", "value": "laptop" }]
            }
          }
        }
      ]
    },
    {
      "name": "🛒 Checkout",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('order_number', res.orderNumber);",
                  "  pm.test('Order created', () => pm.expect(res.orderNumber).to.exist);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/checkout/create-order",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"quantity\": 1\n    }\n  ],\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"shippingAddress\": \"123 Main St, New York, NY 10001\",\n  \"cardNumber\": \"4111111111111111\",\n  \"cardName\": \"John Doe\",\n  \"expiry\": \"12/26\",\n  \"cvc\": \"123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📦 Orders",
      "item": [
        {
          "name": "Track Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/orders/track",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderNumber\": \"{{order_number}}\"\n}"
            }
          }
        }
      ]
    }
  ]
}
